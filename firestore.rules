/**
 * @file firestore.rules
 * @description Firestore Security Rules for the IILM Connect application.
 *
 * @section Core Philosophy
 * This ruleset enforces a strict, user-centric security model. Data is segregated into two main categories:
 * 1. Private User Data: Information stored under the `/users/{userId}` path is strictly owned by and accessible only to that user, unless an admin role is required.
 * 2. Shared/Public Content: Top-level collections like `/posts`, `/comments`, and `/classes` are generally readable by any authenticated user but can only be modified by their designated owner (e.g., author, teacher) or an admin.
 *
 * @section Data Structure
 * The data is organized into a combination of user-nested subcollections for private data (e.g., profiles, notifications) and top-level collections for shared application data. This structure optimizes for common query patterns and simplifies security logic.
 *
 * @section Key Security Decisions
 * - Default Deny: All paths are closed by default. Access is granted on a per-collection basis.
 * - Authentication Required: No data is accessible to unauthenticated users. All rules require a user to be signed in.
 * - Admin Role: An `isAdmin()` function checks the `userType` on a user's document, granting elevated privileges for managing content and users.
 * - No User Listing (for non-admins): The top-level `/users` collection cannot be listed by regular users, preventing enumeration of all application users.
 * - Admin-Managed Content: Collections without a clear ownership model in the schema (e.g., `/tags`, `/mess_meals`) are configured as read-only for general users. Writes to these collections are restricted to admins.
 *
 * @section Denormalization for Authorization
 * To ensure fast and simple authorization, ownership and role data are denormalized directly onto the documents being secured. For example, `Post` documents contain an `authorId` and `Class` documents contain a `teacherId`. This avoids slow, costly, and sometimes impossible cross-document `get()` calls in rules.
 *
 * @section Structural Segregation
 * Private user data (profiles, notifications) is stored in subcollections under `/users/{userId}`, which is inherently more secure for list operations than mixing private and public data in a single top-level collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * @description Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if a document currently exists in Firestore.
     * Essential for secure update and delete operations.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * @description A composite check for update/delete operations, ensuring the
     * user is the owner AND the document already exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDoc();
    }
    
    /**
     * @description Checks if the current user has the 'admin' userType.
     * This grants elevated privileges across the application.
     */
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'admin';
    }

    /**
     * @description Checks if the requesting user is the teacher of a given class.
     * Requires a cross-document read to the parent Class document.
     */
    function isTeacherOfClass(classId) {
      return isSignedIn() && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // User Data (/users)
    // -------------------------------------------------------------------------

    /**
     * @description Manages core user account data.
     * @path /users/{userId}
     * @allow (get) A user can get their own document. An admin can get any user's document.
     * @allow (list) Only admins can list all users.
     * @principle Enforces Self-Creation and Ownership, with admin override.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();

      /**
       * @description Manages a user's student profile.
       * @path /users/{userId}/student_profile/{profileId}
       * @principle Restricts access to a user's own data tree, with admin override.
       */
      match /student_profile/{profileId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      /**
       * @description Manages a user's faculty profile.
       * @path /users/{userId}/faculty_profile/{profileId}
       * @principle Restricts access to a user's own data tree, with admin override.
       */
      match /faculty_profile/{profileId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      /**
       * @description Manages a user's alumni profile.
       * @path /users/{userId}/alumni_profile/{profileId}
       * @principle Restricts access to a user's own data tree, with admin override.
       */
      match /alumni_profile/{profileId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      /**
       * @description Manages a user's notifications.
       * @path /users/{userId}/notifications/{notificationId}
       * @principle Restricts access to a user's own data tree. Notifications are system-generated.
       */
      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if false; // Notifications are created by a backend service, not the client.
        allow update: if isExistingOwner(userId); // User can mark as read.
        allow delete: if isExistingOwner(userId);
      }
      
      /**
       * @description Manages a user's grades.
       * @path /users/{userId}/grades/{gradeId}
       * @principle A user can see their own grades. A teacher can see grades for their class. Admins can see all.
       */
      match /grades/{gradeId} {
        allow get: if isOwner(userId) || isTeacherOfClass(resource.data.classId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isTeacherOfClass(request.resource.data.classId) || isAdmin();
      }
    }

    // -------------------------------------------------------------------------
    // CollabNest Portal (/posts)
    // -------------------------------------------------------------------------

    /**
     * @description Manages public posts.
     * @path /posts/{postId}
     * @allow (update) Any signed-in user can update the `likedBy` field. The author or an admin can update the whole document.
     * @principle Implements Public Read with Owner/Admin-Only Writes, but allows any user to like.
     */
    match /posts/{postId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if (isExistingOwner(resource.data.authorId) || isAdmin()) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy']));
      allow delete: if isExistingOwner(resource.data.authorId) || isAdmin();

      /**
       * @description Manages comments on a post.
       * @path /posts/{postId}/comments/{commentId}
       * @principle Implements Public Read with Owner/Admin-Only Writes.
       */
      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if isExistingOwner(resource.data.authorId) || isAdmin();
        allow delete: if isExistingOwner(resource.data.authorId) || isAdmin();
      }
    }

    /**
     * @description Manages tags for posts.
     * @path /tags/{tagId}
     * @principle Read-only for clients. Managed by admins.
     */
    match /tags/{tagId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // LMS Portal (/classes)
    // -------------------------------------------------------------------------

    /**
     * @description Manages class/course information.
     * @path /classes/{classId}
     * @principle Public Read with Teacher/Admin-Only Writes.
     */
    match /classes/{classId} {
      allow get, list: if isSignedIn();
      allow create: if isTeacherOfClass(classId) || isAdmin();
      allow update: if isTeacherOfClass(classId) || isAdmin();
      allow delete: if isTeacherOfClass(classId) || isAdmin();

      /**
       * @description Manages student attendance for a class.
       * @path /classes/{classId}/attendances/{attendanceId}
       * @principle The teacher has full control, while the student has read-only access to their own data.
       */
      match /attendances/{attendanceId} {
        allow get: if isTeacherOfClass(classId) || (isExistingDoc() && isOwner(resource.data.studentId));
        allow list: if isTeacherOfClass(classId);
        allow create, update, delete: if isTeacherOfClass(classId);
      }
      
      /**
       * @description Manages assignments for a class.
       * @path /classes/{classId}/assignments/{assignmentId}
       * @principle All authenticated users can read assignments, but only the teacher or an admin can manage them.
       */
       match /assignments/{assignmentId} {
        allow get, list: if isSignedIn();
        allow write: if isTeacherOfClass(classId) || isAdmin();
       }
    }

    // -------------------------------------------------------------------------
    // Mess Portal (/mess_meals)
    // -------------------------------------------------------------------------

    /**
     * @description Manages available mess meals.
     * @path /mess_meals/{mealId}
     * @principle Read-only for clients. Managed by admins.
     */
    match /mess_meals/{mealId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();

      /**
       * @description Manages consumption data entered by mess staff.
       * @path /mess_meals/{mealId}/staff_consumption_data/{consumptionDataId}
       * @principle Read-only for clients. Managed by admins or a future 'mess_staff' role.
       */
      match /staff_consumption_data/{consumptionDataId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin(); // Replace with `isMessStaff()` if role is added
      }
    }

    /**
     * @description Manages student meal selections.
     * @path /student_meal_selections/{selectionId}
     * @principle Enforces strict data ownership for privacy.
     */
    match /student_meal_selections/{selectionId} {
      allow get: if isOwner(resource.data.studentId);
      allow list: if isSignedIn() && request.query.where.studentId == request.auth.uid;
      allow create: if isOwner(request.resource.data.studentId);
      allow update: if isExistingOwner(resource.data.studentId);
      allow delete: if isExistingOwner(resource.data.studentId);
    }
  }
}
    