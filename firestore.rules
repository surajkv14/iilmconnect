rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }

    // Allow read and write access to any document for any signed-in user.
    // This is a temporary, permissive rule for development.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
