
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a student, faculty, or mess staff member.",
      "properties": {
        "id": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "bio": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "userType": {
          "type": "string",
          "enum": ["student", "mess_staff", "admin"]
        },
        "dietaryPreferences": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allergies": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "email", "userType"]
    },
    "MessMeal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MessMeal",
      "type": "object",
      "description": "Represents a meal item or menu for a specific day/type.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["breakfast", "lunch", "dinner", "snack"] },
        "date": { "type": "string", "format": "date" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "category": { "type": "string", "enum": ["Veg", "Non-Veg", "Vegan"] },
              "calories": { "type": "number" }
            }
          }
        }
      },
      "required": ["id", "name", "type", "date"]
    },
    "MealBooking": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MealBooking",
      "type": "object",
      "description": "A student's commitment to eat a specific meal.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "mealId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "mealType": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["booked", "consumed", "cancelled"] }
      },
      "required": ["studentId", "mealId", "status", "date", "mealType"]
    },
    "WasteData": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WasteData",
      "type": "object",
      "description": "Daily waste metrics for mess optimization.",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "mealType": { "type": "string" },
        "wastedKgs": { "type": "number" },
        "reason": { "type": "string" }
      },
      "required": ["date", "mealType", "wastedKgs"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles and mess preferences."
        }
      },
      {
        "path": "/menu/{mealId}",
        "definition": {
          "entityName": "MessMeal",
          "schema": { "$ref": "#/backend/entities/MessMeal" },
          "description": "Daily menu items."
        }
      },
      {
        "path": "/bookings/{bookingId}",
        "definition": {
          "entityName": "MealBooking",
          "schema": { "$ref": "#/backend/entities/MealBooking" },
          "description": "Student meal reservations."
        }
      },
      {
        "path": "/waste_logs/{logId}",
        "definition": {
          "entityName": "WasteData",
          "schema": { "$ref": "#/backend/entities/WasteData" },
          "description": "Tracking food waste for sustainability."
        }
      }
    ]
  }
}
