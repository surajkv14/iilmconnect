
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a student, faculty, or mess staff member.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" },
        "userType": { "type": "string", "enum": ["student", "mess_staff", "admin"] },
        "dietaryPreferences": { "type": "array", "items": { "type": "string" } },
        "allergies": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "email", "userType"]
    },
    "MessMeal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MessMeal",
      "type": "object",
      "description": "Represents a meal item or menu for a specific day/type.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["breakfast", "lunch", "dinner"] },
        "date": { "type": "string", "format": "date" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "category": { "type": "string", "enum": ["Veg", "Non-Veg", "Vegan"] },
              "calories": { "type": "number" }
            }
          }
        }
      },
      "required": ["type", "date"]
    },
    "MealBooking": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MealBooking",
      "type": "object",
      "description": "A student's commitment to eat a specific meal.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "mealId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "mealType": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["booked", "consumed", "cancelled"] },
        "couponCode": { "type": "string" }
      },
      "required": ["studentId", "status", "date", "mealType", "couponCode"]
    },
    "Poll": {
      "title": "Poll",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "votes": { "type": "number" }
            }
          }
        },
        "voters": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Feedback": {
      "title": "Feedback",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "message": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "schema": { "$ref": "#/backend/entities/User" } }
      },
      {
        "path": "/menu/{mealId}",
        "definition": { "schema": { "$ref": "#/backend/entities/MessMeal" } }
      },
      {
        "path": "/bookings/{bookingId}",
        "definition": { "schema": { "$ref": "#/backend/entities/MealBooking" } }
      },
      {
        "path": "/polls/{pollId}",
        "definition": { "schema": { "$ref": "#/backend/entities/Poll" } }
      },
      {
        "path": "/feedback/{feedbackId}",
        "definition": { "schema": { "$ref": "#/backend/entities/Feedback" } }
      },
      {
        "path": "/notifications/{notifId}",
        "definition": { "schema": { "$ref": "#/backend/entities/Notification" } }
      }
    ]
  }
}
